{
  "$description": "Feedback component tokens: badge, tag, alert, notification, progress, spinner. Chain: component → semantic → primitive.",
  "badge": {
    "padding": {
      "x": { "$value": "{space.8}", "$type": "number" },
      "y": { "$value": "{space.4}", "$type": "number" }
    },
    "border": {
      "radius": { "$value": "{radius.12}", "$type": "number" }
    },
    "font": {
      "size":    { "$value": "{font.size.12}",      "$type": "number" },
      "weight":  { "$value": "{font.weight.semibold}", "$type": "number" },
      "leading": { "$value": "{font.leading.120}",  "$type": "number" }
    },
    "dot": {
      "size":         { "$value": 6,           "$type": "number" },
      "margin-right": { "$value": "{space.6}", "$type": "number" }
    },
    "primary": {
      "bg":     { "$value": "{color.blue.100}", "$type": "color", "$description": "Badge variant colors use primitives directly — no semantic badge-color tokens exist yet" },
      "text":   { "$value": "{color.blue.900}", "$type": "color" },
      "border": { "$value": "{color.blue.300}", "$type": "color" }
    },
    "success": {
      "bg":     { "$value": "{color.success.50}",  "$type": "color" },
      "text":   { "$value": "{color.success.900}", "$type": "color" },
      "border": { "$value": "{color.success.300}", "$type": "color" }
    },
    "warning": {
      "bg":     { "$value": "{color.warning.50}",  "$type": "color" },
      "text":   { "$value": "{color.warning.900}", "$type": "color" },
      "border": { "$value": "{color.warning.300}", "$type": "color" }
    },
    "error": {
      "bg":     { "$value": "{color.error.50}",    "$type": "color" },
      "text":   { "$value": "{color.error.900}",   "$type": "color" },
      "border": { "$value": "{color.error.300}",   "$type": "color" }
    },
    "info": {
      "bg":     { "$value": "{color.info.50}",     "$type": "color" },
      "text":   { "$value": "{color.info.900}",    "$type": "color" },
      "border": { "$value": "{color.info.300}",    "$type": "color" }
    },
    "neutral": {
      "bg":     { "$value": "{color.neutral.100}", "$type": "color" },
      "text":   { "$value": "{color.neutral.900}", "$type": "color" },
      "border": { "$value": "{color.neutral.300}", "$type": "color" }
    }
  },

  "tag": {
    "padding": {
      "x": { "$value": "{space.12}", "$type": "number" },
      "y": { "$value": "{space.6}",  "$type": "number" }
    },
    "border": {
      "radius": { "$value": "{radius.6}", "$type": "number" }
    },
    "font": {
      "size":    { "$value": "{font.size.12}",      "$type": "number" },
      "weight":  { "$value": "{font.weight.normal}", "$type": "number" },
      "leading": { "$value": "{font.leading.140}",  "$type": "number" }
    },
    "bg": {
      "default":        { "$value": "{color.neutral.100}", "$type": "color" },
      "removable-hover":{ "$value": "{color.neutral.200}", "$type": "color" }
    },
    "text":   { "$value": "{color.text.primary}",   "$type": "color" },
    "border": { "$value": "{color.border.default}", "$type": "color" },
    "remove-button": {
      "size":   { "$value": "{size.icon.sm}", "$type": "number" },
      "margin": { "$value": "{space.6}",      "$type": "number" }
    },
    "transition": { "$value": "{transition.fast}", "$type": "number" }
  },

  "alert": {
    "padding": {
      "x": { "$value": "{space.16}", "$type": "number" },
      "y": { "$value": "{space.12}", "$type": "number" }
    },
    "border": {
      "radius": { "$value": "{radius.6}",             "$type": "number" },
      "width":  { "$value": "{border.width.default}", "$type": "number" }
    },
    "icon": {
      "size":         { "$value": "{size.icon.lg}", "$type": "number" },
      "margin-right": { "$value": "{space.12}",     "$type": "number" }
    },
    "close-button": {
      "size":   { "$value": "{size.icon.lg}", "$type": "number" },
      "margin": { "$value": "{space.12}",     "$type": "number" }
    },
    "success": {
      "bg":         { "$value": "{color.success.50}",  "$type": "color" },
      "border":     { "$value": "{color.success.300}", "$type": "color" },
      "icon-color": { "$value": "{color.success.600}", "$type": "color" },
      "text":       { "$value": "{color.success.900}", "$type": "color" }
    },
    "warning": {
      "bg":         { "$value": "{color.warning.50}",  "$type": "color" },
      "border":     { "$value": "{color.warning.300}", "$type": "color" },
      "icon-color": { "$value": "{color.warning.600}", "$type": "color" },
      "text":       { "$value": "{color.warning.900}", "$type": "color" }
    },
    "error": {
      "bg":         { "$value": "{color.error.50}",    "$type": "color" },
      "border":     { "$value": "{color.error.300}",   "$type": "color" },
      "icon-color": { "$value": "{color.error.600}",   "$type": "color" },
      "text":       { "$value": "{color.error.900}",   "$type": "color" }
    },
    "info": {
      "bg":         { "$value": "{color.info.50}",     "$type": "color" },
      "border":     { "$value": "{color.info.300}",    "$type": "color" },
      "icon-color": { "$value": "{color.info.600}",    "$type": "color" },
      "text":       { "$value": "{color.info.900}",    "$type": "color" }
    }
  },

  "notification": {
    "padding": {
      "x": { "$value": "{space.16}", "$type": "number" },
      "y": { "$value": "{space.12}", "$type": "number" }
    },
    "border": {
      "radius": { "$value": "{radius.6}", "$type": "number" }
    },
    "shadow":          { "$value": "{shadow.lg}", "$type": "string", "$figmaExclude": true },
    "icon":            { "$value": "{size.icon.lg}", "$type": "number" },
    "icon-margin":     { "$value": "{space.12}",     "$type": "number" },
    "close-button":    { "$value": "{size.icon.sm}", "$type": "number" },
    "close-margin":    { "$value": "{space.12}",     "$type": "number" },
    "position-offset": { "$value": "{space.16}",     "$type": "number" },
    "success": {
      "bg":     { "$value": "{color.success.50}",  "$type": "color" },
      "border": { "$value": "{color.success.300}", "$type": "color" },
      "text":   { "$value": "{color.success.900}", "$type": "color" }
    },
    "error": {
      "bg":     { "$value": "{color.error.50}",    "$type": "color" },
      "border": { "$value": "{color.error.300}",   "$type": "color" },
      "text":   { "$value": "{color.error.900}",   "$type": "color" }
    },
    "warning": {
      "bg":     { "$value": "{color.warning.50}",  "$type": "color" },
      "border": { "$value": "{color.warning.300}", "$type": "color" },
      "text":   { "$value": "{color.warning.900}", "$type": "color" }
    },
    "info": {
      "bg":     { "$value": "{color.info.50}",     "$type": "color" },
      "border": { "$value": "{color.info.300}",    "$type": "color" },
      "text":   { "$value": "{color.info.900}",    "$type": "color" }
    }
  },

  "progress": {
    "height":        { "$value": 4,                "$type": "number" },
    "border-radius": { "$value": "{radius.full}",  "$type": "number" },
    "bg": {
      "default": { "$value": "{color.border.light}", "$type": "color" },
      "filled":  { "$value": "{color.blue.500}",     "$type": "color" },
      "success": { "$value": "{color.success.500}",  "$type": "color" },
      "warning": { "$value": "{color.warning.500}",  "$type": "color" },
      "error":   { "$value": "{color.error.500}",    "$type": "color" }
    },
    "text": {
      "size":   { "$value": "{font.size.12}",      "$type": "number" },
      "weight": { "$value": "{font.weight.medium}", "$type": "number" },
      "color":  { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  },

  "spinner": {
    "size": {
      "sm": { "$value": "{size.icon.sm}", "$type": "number" },
      "md": { "$value": "{size.icon.lg}", "$type": "number" },
      "lg": { "$value": "{size.icon.xl}", "$type": "number" }
    },
    "stroke": {
      "width": { "$value": 2,                       "$type": "number" },
      "color": { "$value": "{color.blue.500}",      "$type": "color" }
    },
    "bg":       { "$value": "{color.border.light}",   "$type": "color" },
    "duration": { "$value": "{animation.duration.base}", "$type": "number" }
  }
}
