{
  "$description": "Form control component tokens: label, helptext, checkbox, radio, toggle, select, form. Chain: component → semantic → primitive.",
  "label": {
    "font": {
      "size":    { "$value": "{font.size.14}",      "$type": "number" },
      "weight":  { "$value": "{font.weight.semibold}", "$type": "number" },
      "leading": { "$value": "{font.leading.140}",  "$type": "number" }
    },
    "color": {
      "default":  { "$value": "{color.text.primary}",  "$type": "color" },
      "disabled": { "$value": "{color.text.disabled}", "$type": "color" }
    },
    "margin-bottom": { "$value": "{space.6}", "$type": "number" }
  },

  "helptext": {
    "font": {
      "size":    { "$value": "{font.size.12}",      "$type": "number" },
      "weight":  { "$value": "{font.weight.normal}", "$type": "number" },
      "leading": { "$value": "{font.leading.140}",  "$type": "number" }
    },
    "color": {
      "default": { "$value": "{color.text.tertiary}",    "$type": "color" },
      "error":   { "$value": "{color.feedback.error}",   "$type": "color" },
      "success": { "$value": "{color.feedback.success}", "$type": "color" }
    },
    "margin-top": { "$value": "{space.4}", "$type": "number" }
  },

  "checkbox": {
    "size":   { "$value": 16, "$type": "number" },
    "border": {
      "radius": { "$value": "{radius.2}",             "$type": "number" },
      "width":  { "$value": "{border.width.default}", "$type": "number" }
    },
    "bg": {
      "unchecked": { "$value": "{color.bg.primary}",                       "$type": "color" },
      "checked":   { "$value": "{color.interactive.primary.default}",      "$type": "color" },
      "disabled":  { "$value": "{color.bg.disabled}",                      "$type": "color" }
    },
    "border-color": {
      "unchecked": { "$value": "{color.border.default}",               "$type": "color" },
      "checked":   { "$value": "{color.interactive.primary.default}",  "$type": "color" },
      "disabled":  { "$value": "{color.border.disabled}",              "$type": "color" }
    },
    "checkmark": { "$value": "{color.white}", "$type": "color" },
    "focus": {
      "outline-width":  { "$value": "{focus.outline.width}",  "$type": "number" },
      "outline-color":  { "$value": "{focus.outline.color}",  "$type": "color" },
      "outline-offset": { "$value": "{focus.outline.offset}", "$type": "number" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  },

  "radio": {
    "size":  { "$value": 16, "$type": "number" },
    "border": {
      "width": { "$value": "{border.width.thick}", "$type": "number" }
    },
    "bg": {
      "unchecked": { "$value": "{color.bg.primary}", "$type": "color" },
      "checked":   { "$value": "{color.bg.primary}", "$type": "color" },
      "disabled":  { "$value": "{color.bg.disabled}", "$type": "color" }
    },
    "border-color": {
      "unchecked": { "$value": "{color.border.default}",              "$type": "color" },
      "checked":   { "$value": "{color.interactive.primary.default}", "$type": "color" },
      "disabled":  { "$value": "{color.border.disabled}",             "$type": "color" }
    },
    "dot": {
      "color": { "$value": "{color.interactive.primary.default}", "$type": "color" },
      "size":  { "$value": 6, "$type": "number" }
    },
    "focus": {
      "outline-width": { "$value": "{focus.outline.width}", "$type": "number" },
      "outline-color": { "$value": "{focus.outline.color}", "$type": "color" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  },

  "toggle": {
    "width":  { "$value": 44, "$type": "number" },
    "height": { "$value": 24, "$type": "number" },
    "border": {
      "radius": { "$value": "{radius.full}", "$type": "number" }
    },
    "bg": {
      "off":      { "$value": "{color.border.default}",               "$type": "color" },
      "on":       { "$value": "{color.interactive.primary.default}",  "$type": "color" },
      "disabled": { "$value": "{color.bg.disabled}",                  "$type": "color" }
    },
    "thumb": {
      "size":   { "$value": 20, "$type": "number" },
      "color":  { "$value": "{color.white}", "$type": "color" },
      "shadow": { "$value": "{shadow.sm}", "$type": "string", "$figmaExclude": true }
    },
    "focus": {
      "outline-width": { "$value": "{focus.outline.width}", "$type": "number" },
      "outline-color": { "$value": "{focus.outline.color}", "$type": "color" }
    },
    "transition": { "$value": "{transition.fast}", "$type": "number" }
  },

  "select": {
    "padding": {
      "x": { "$value": "{space.12}", "$type": "number" },
      "y": { "$value": "{space.8}",  "$type": "number" }
    },
    "border": {
      "radius": { "$value": "{radius.4}",             "$type": "number" },
      "width":  { "$value": "{border.width.default}", "$type": "number" }
    },
    "font": {
      "size":    { "$value": "{font.size.16}",   "$type": "number" },
      "leading": { "$value": "{font.leading.150}", "$type": "number" }
    },
    "size": {
      "min-height": { "$value": "{size.component.md}", "$type": "number" }
    },
    "bg": {
      "default":  { "$value": "{color.bg.primary}",  "$type": "color" },
      "disabled": { "$value": "{color.bg.disabled}", "$type": "color" }
    },
    "border-color": {
      "default": { "$value": "{color.border.default}",                    "$type": "color" },
      "hover":   { "$value": "{color.border.strong}",                     "$type": "color" },
      "focus":   { "$value": "{color.interactive.primary.default}",       "$type": "color" }
    },
    "text": {
      "default":     { "$value": "{color.text.primary}",   "$type": "color" },
      "disabled":    { "$value": "{color.text.disabled}",  "$type": "color" },
      "placeholder": { "$value": "{color.text.tertiary}",  "$type": "color" }
    },
    "icon": {
      "size":  { "$value": "{size.icon.sm}", "$type": "number" },
      "color": { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  },

  "form": {
    "gap": { "$value": "{space.16}", "$type": "number" },
    "fieldset": {
      "padding": { "$value": "{space.16}", "$type": "number" },
      "border": {
        "width":  { "$value": "{border.width.default}", "$type": "number" },
        "color":  { "$value": "{color.border.default}", "$type": "color" },
        "radius": { "$value": "{radius.4}", "$type": "number" }
      },
      "legend": {
        "padding": {
          "x": { "$value": "{space.8}", "$type": "number" },
          "y": { "$value": "{space.4}", "$type": "number" }
        }
      }
    }
  }
}
