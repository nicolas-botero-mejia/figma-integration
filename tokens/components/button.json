{
  "$description": "Button component tokens. Chain: component → semantic → primitive. Never alias directly to a primitive.",
  "button": {
    "padding": {
      "sm": {
        "x": { "$value": "{space.12}", "$type": "number" },
        "y": { "$value": "{space.6}",  "$type": "number" }
      },
      "md": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.8}",  "$type": "number" }
      },
      "lg": {
        "x": { "$value": "{space.20}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      }
    },
    "border": {
      "radius": { "$value": "{radius.6}",         "$type": "number" },
      "width":  { "$value": "{border.width.default}", "$type": "number" }
    },
    "font": {
      "size":    { "$value": "{font.size.16}",     "$type": "number" },
      "weight":  { "$value": "{font.weight.semibold}", "$type": "number" },
      "leading": { "$value": "{font.leading.150}", "$type": "number" },
      "tracking":{ "$value": "{font.tracking.normal}", "$type": "string", "$figmaExclude": true }
    },
    "size": {
      "min-height": { "$value": "{size.component.md}", "$type": "number" },
      "min-width":  { "$value": 80, "$type": "number", "$description": "Minimum tap target width — not a primitive alias; intentional fixed value per UX spec" }
    },
    "focus": {
      "outline-width":  { "$value": "{focus.outline.width}",  "$type": "number" },
      "outline-color":  { "$value": "{focus.outline.color}",  "$type": "color" },
      "outline-offset": { "$value": "{focus.outline.offset}", "$type": "number" }
    },
    "disabled": {
      "opacity": { "$value": "{disabled.opacity}", "$type": "number" },
      "cursor":  { "$value": "{disabled.cursor}",  "$type": "string" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" },
    "primary": {
      "bg": {
        "default":  { "$value": "{color.interactive.primary.default}",  "$type": "color" },
        "hover":    { "$value": "{color.interactive.primary.hover}",    "$type": "color" },
        "pressed":  { "$value": "{color.interactive.primary.pressed}",  "$type": "color" },
        "disabled": { "$value": "{color.interactive.primary.disabled}", "$type": "color" }
      },
      "text": {
        "default":  { "$value": "{color.white}",        "$type": "color" },
        "disabled": { "$value": "{color.text.disabled}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.transparent}", "$type": "color" },
        "hover":   { "$value": "{color.transparent}", "$type": "color" }
      },
      "shadow": {
        "default": { "$value": "{shadow.none}", "$type": "string", "$figmaExclude": true },
        "hover":   { "$value": "{shadow.sm}",   "$type": "string", "$figmaExclude": true }
      }
    },
    "secondary": {
      "bg": {
        "default":  { "$value": "{color.interactive.secondary.default}",  "$type": "color" },
        "hover":    { "$value": "{color.interactive.secondary.hover}",    "$type": "color" },
        "pressed":  { "$value": "{color.interactive.secondary.pressed}",  "$type": "color" },
        "disabled": { "$value": "{color.interactive.secondary.disabled}", "$type": "color" }
      },
      "text": {
        "default":  { "$value": "{color.interactive.secondary.text}", "$type": "color" },
        "disabled": { "$value": "{color.text.disabled}",              "$type": "color" }
      },
      "border": {
        "default": { "$value": "{color.border.default}", "$type": "color" },
        "hover":   { "$value": "{color.border.strong}",  "$type": "color" }
      }
    },
    "tertiary": {
      "bg": {
        "default": { "$value": "{color.interactive.tertiary.default}", "$type": "color" },
        "hover":   { "$value": "{color.interactive.tertiary.hover}",   "$type": "color" },
        "pressed": { "$value": "{color.interactive.tertiary.pressed}", "$type": "color" }
      },
      "text": {
        "default": { "$value": "{color.interactive.tertiary.text}", "$type": "color" },
        "hover":   { "$value": "{color.interactive.primary.hover}", "$type": "color" }
      }
    },
    "danger": {
      "bg": {
        "default":  { "$value": "{color.interactive.danger.default}",  "$type": "color" },
        "hover":    { "$value": "{color.interactive.danger.hover}",    "$type": "color" },
        "pressed":  { "$value": "{color.interactive.danger.pressed}",  "$type": "color" },
        "disabled": { "$value": "{color.interactive.danger.disabled}", "$type": "color" }
      },
      "text": {
        "default":  { "$value": "{color.white}",        "$type": "color" },
        "disabled": { "$value": "{color.text.disabled}", "$type": "color" }
      }
    },
    "success": {
      "bg": {
        "default": { "$value": "{color.interactive.success.default}", "$type": "color" },
        "hover":   { "$value": "{color.interactive.success.hover}",   "$type": "color" },
        "pressed": { "$value": "{color.interactive.success.pressed}", "$type": "color" }
      },
      "text": {
        "default":  { "$value": "{color.white}",        "$type": "color" },
        "disabled": { "$value": "{color.text.disabled}", "$type": "color" }
      }
    }
  }
}
