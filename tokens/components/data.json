{
  "$description": "Data component tokens: data-table, chart. Chain: component → semantic → primitive.",
  "table": {
    "border": {
      "width": { "$value": "{border.width.default}", "$type": "number" },
      "color": { "$value": "{color.border.light}", "$type": "color" }
    },
    "header": {
      "bg":          { "$value": "{color.bg.secondary}",    "$type": "color" },
      "text":        { "$value": "{color.text.primary}",   "$type": "color" },
      "font-weight": { "$value": "{font.weight.semibold}", "$type": "number" },
      "font-size":   { "$value": "{font.size.14}",         "$type": "number" },
      "padding": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      }
    },
    "cell": {
      "padding": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      },
      "text":      { "$value": "{color.text.primary}", "$type": "color" },
      "font-size": { "$value": "{font.size.14}",       "$type": "number" }
    },
    "row": {
      "height":      { "$value": 44,                      "$type": "number" },
      "hover-bg":    { "$value": "{color.bg.tertiary}",   "$type": "color" },
      "selected-bg": { "$value": "{color.blue.50}",       "$type": "color", "$description": "No semantic selected-bg token yet — add color.bg.selected to semantic/color.json in Phase 2" },
      "striped-bg":  { "$value": "{color.bg.secondary}",  "$type": "color" }
    },
    "footer": {
      "bg":      { "$value": "{color.bg.secondary}",  "$type": "color" },
      "padding": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      },
      "text":    { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "sticky": {
      "header-shadow": { "$value": "{shadow.sm}", "$type": "string", "$figmaExclude": true },
      "column-shadow": { "$value": "{shadow.sm}", "$type": "string", "$figmaExclude": true }
    },
    "resize-handle": {
      "width":  { "$value": 4,                        "$type": "number" },
      "color":  { "$value": "{color.border.strong}",  "$type": "color" },
      "active": { "$value": "{color.blue.500}",        "$type": "color" }
    },
    "sort-icon": {
      "size":  { "$value": 14,                         "$type": "number" },
      "color": { "$value": "{color.text.secondary}",   "$type": "color" }
    }
  },

  "chart": {
    "padding": { "$value": "{space.16}", "$type": "number" },
    "title": {
      "size":   { "$value": "{font.size.16}",        "$type": "number" },
      "weight": { "$value": "{font.weight.semibold}", "$type": "number" },
      "margin": { "$value": "{space.12}",             "$type": "number" }
    },
    "axis": {
      "label-size":  { "$value": "{font.size.12}",        "$type": "number" },
      "label-color": { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "grid": {
      "color": { "$value": "{color.border.light}",    "$type": "color" },
      "width": { "$value": "{border.width.default}",  "$type": "number" }
    },
    "legend": {
      "font-size": { "$value": "{font.size.12}", "$type": "number" },
      "gap":       { "$value": "{space.12}",     "$type": "number" },
      "padding":   { "$value": "{space.12}",     "$type": "number" }
    },
    "tooltip": {
      "bg":      { "$value": "{color.neutral.900}", "$type": "color", "$description": "Dark tooltip bg — intentional, no semantic inverse-surface token yet; add color.bg.inverse to semantic/color.json in Phase 2" },
      "text":    { "$value": "{color.white}",       "$type": "color" },
      "padding": {
        "x": { "$value": "{space.8}", "$type": "number" },
        "y": { "$value": "{space.6}", "$type": "number" }
      },
      "border-radius": { "$value": "{radius.4}",   "$type": "number" },
      "shadow":        { "$value": "{shadow.lg}",  "$type": "string", "$figmaExclude": true }
    },
    "series": {
      "1": { "$value": "{color.chart.1}", "$type": "color" },
      "2": { "$value": "{color.chart.2}", "$type": "color" },
      "3": { "$value": "{color.chart.3}", "$type": "color" },
      "4": { "$value": "{color.chart.4}", "$type": "color" },
      "5": { "$value": "{color.chart.5}", "$type": "color" },
      "6": { "$value": "{color.chart.6}", "$type": "color" }
    }
  }
}
