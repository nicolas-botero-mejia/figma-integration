{
  "$description": "Layout component tokens: card, modal, divider, accordion. Chain: component → semantic → primitive.",
  "card": {
    "padding":       { "$value": "{space.16}",           "$type": "number" },
    "border": {
      "radius": { "$value": "{radius.8}",             "$type": "number" },
      "width":  { "$value": "{border.width.default}", "$type": "number" },
      "color":  { "$value": "{color.border.light}",   "$type": "color" }
    },
    "bg": {
      "default": { "$value": "{color.bg.primary}",   "$type": "color" },
      "hover":   { "$value": "{color.bg.secondary}", "$type": "color" }
    },
    "shadow": {
      "default": { "$value": "{shadow.sm}", "$type": "string", "$figmaExclude": true },
      "hover":   { "$value": "{shadow.md}", "$type": "string", "$figmaExclude": true },
      "focused": { "$value": "{shadow.lg}", "$type": "string", "$figmaExclude": true }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" },
    "header": {
      "padding":      { "$value": "{space.16}",              "$type": "number" },
      "border-width": { "$value": "{border.width.default}",  "$type": "number" },
      "border-color": { "$value": "{color.border.light}",    "$type": "color" }
    },
    "body": {
      "padding": { "$value": "{space.16}",           "$type": "number" },
      "text":    { "$value": "{color.text.primary}", "$type": "color" }
    },
    "footer": {
      "padding":      { "$value": "{space.16}",              "$type": "number" },
      "border-width": { "$value": "{border.width.default}",  "$type": "number" },
      "border-color": { "$value": "{color.border.light}",    "$type": "color" },
      "bg":           { "$value": "{color.bg.secondary}",    "$type": "color" }
    }
  },

  "modal": {
    "border-radius": { "$value": "{radius.8}",          "$type": "number" },
    "bg":            { "$value": "{color.bg.primary}",  "$type": "color" },
    "shadow":        { "$value": "{shadow.xl}",         "$type": "string", "$figmaExclude": true },
    "padding":       { "$value": "{space.24}",          "$type": "number" },
    "max-width": {
      "sm": { "$value": 400,  "$type": "number" },
      "md": { "$value": 600,  "$type": "number" },
      "lg": { "$value": 800,  "$type": "number" },
      "xl": { "$value": 1000, "$type": "number" }
    },
    "header": {
      "padding":      { "$value": "{space.24}",              "$type": "number" },
      "border-width": { "$value": "{border.width.default}",  "$type": "number" },
      "border-color": { "$value": "{color.border.light}",    "$type": "color" }
    },
    "body": {
      "padding": { "$value": "{space.24}", "$type": "number" }
    },
    "footer": {
      "padding":      { "$value": "{space.24}",              "$type": "number" },
      "border-width": { "$value": "{border.width.default}",  "$type": "number" },
      "border-color": { "$value": "{color.border.light}",    "$type": "color" },
      "bg":           { "$value": "{color.bg.secondary}",    "$type": "color" },
      "gap":          { "$value": "{space.12}",              "$type": "number" }
    },
    "close-button": {
      "size":  { "$value": "{size.icon.lg}",         "$type": "number" },
      "color": { "$value": "{color.text.secondary}", "$type": "color" }
    },
    "backdrop": {
      "bg":         { "$value": "{color.bg.overlay}", "$type": "color", "$figmaExclude": true },
      "transition": { "$value": "{transition.base}",  "$type": "number" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  },

  "divider": {
    "height": { "$value": "{border.width.1}",      "$type": "number", "$description": "Uses primitive directly — divider height is a sizing unit, not a semantic border concept" },
    "color":  { "$value": "{color.border.light}",  "$type": "color" },
    "margin": {
      "x": { "$value": "{space.0}",  "$type": "number" },
      "y": { "$value": "{space.16}", "$type": "number" }
    },
    "text": {
      "margin": { "$value": "{space.12}",           "$type": "number" },
      "size":   { "$value": "{font.size.12}",       "$type": "number" },
      "color":  { "$value": "{color.text.secondary}", "$type": "color" }
    }
  },

  "accordion": {
    "border": {
      "width":  { "$value": "{border.width.default}", "$type": "number" },
      "color":  { "$value": "{color.border.light}",   "$type": "color" },
      "radius": { "$value": "{radius.6}",             "$type": "number" }
    },
    "header": {
      "padding": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      },
      "bg": {
        "default": { "$value": "{color.bg.secondary}", "$type": "color" },
        "hover":   { "$value": "{color.bg.tertiary}",  "$type": "color" }
      },
      "font": {
        "size":   { "$value": "{font.size.14}",        "$type": "number" },
        "weight": { "$value": "{font.weight.semibold}", "$type": "number" }
      },
      "text": { "$value": "{color.text.primary}", "$type": "color" }
    },
    "icon": {
      "size":          { "$value": "{size.icon.md}",     "$type": "number" },
      "color":         { "$value": "{color.text.secondary}", "$type": "color" },
      "rotation-open": { "$value": "180deg",             "$type": "string" }
    },
    "body": {
      "padding": { "$value": "{space.16}",           "$type": "number" },
      "bg":      { "$value": "{color.bg.primary}",   "$type": "color" },
      "text":    { "$value": "{color.text.primary}", "$type": "color" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  }
}
