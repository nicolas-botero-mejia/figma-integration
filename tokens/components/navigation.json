{
  "$description": "Navigation component tokens: tabs, breadcrumb, pagination, link. Chain: component → semantic → primitive.",
  "tabs": {
    "gap": { "$value": "{space.0}", "$type": "number" },
    "tab": {
      "padding": {
        "x": { "$value": "{space.16}", "$type": "number" },
        "y": { "$value": "{space.12}", "$type": "number" }
      },
      "border": {
        "width":  { "$value": "{border.width.thick}", "$type": "number" },
        "radius": { "$value": "{radius.0}",       "$type": "number" }
      },
      "font": {
        "size":   { "$value": "{font.size.14}",       "$type": "number" },
        "weight": { "$value": "{font.weight.semibold}", "$type": "number" }
      },
      "text": {
        "default":  { "$value": "{color.text.secondary}", "$type": "color" },
        "active":   { "$value": "{color.text.primary}",   "$type": "color" },
        "disabled": { "$value": "{color.text.disabled}",  "$type": "color" }
      },
      "border-color": {
        "default":  { "$value": "{color.transparent}", "$type": "color" },
        "active":   { "$value": "{color.blue.500}",    "$type": "color" },
        "disabled": { "$value": "{color.transparent}", "$type": "color" }
      },
      "bg": {
        "default":  { "$value": "{color.transparent}",   "$type": "color" },
        "hover":    { "$value": "{color.neutral.50}",    "$type": "color" },
        "active":   { "$value": "{color.transparent}",   "$type": "color" },
        "disabled": { "$value": "{color.transparent}",   "$type": "color" }
      },
      "transition": { "$value": "{transition.base}", "$type": "number" }
    }
  },

  "breadcrumb": {
    "padding": {
      "x": { "$value": "{space.12}", "$type": "number" },
      "y": { "$value": "{space.8}",  "$type": "number" }
    },
    "gap": { "$value": "{space.8}", "$type": "number" },
    "link": {
      "font-size": { "$value": "{font.size.14}", "$type": "number" },
      "color": {
        "default":  { "$value": "{color.blue.500}",   "$type": "color" },
        "hover":    { "$value": "{color.blue.600}",   "$type": "color" },
        "visited":  { "$value": "{color.purple.600}", "$type": "color", "$description": "Visited link color — no semantic link-color token; intentional until link palette is defined" }
      }
    },
    "separator": {
      "margin-x": { "$value": "{space.4}",            "$type": "number" },
      "color":    { "$value": "{color.text.tertiary}", "$type": "color" }
    }
  },

  "pagination": {
    "gap": { "$value": "{space.8}", "$type": "number" },
    "button": {
      "size":    { "$value": 32,              "$type": "number" },
      "padding": { "$value": "{space.8}",     "$type": "number" },
      "border": {
        "radius": { "$value": "{radius.4}",             "$type": "number" },
        "width":  { "$value": "{border.width.default}", "$type": "number" }
      },
      "bg": {
        "default": { "$value": "{color.bg.primary}",  "$type": "color" },
        "hover":   { "$value": "{color.neutral.100}", "$type": "color" },
        "active":  { "$value": "{color.blue.500}",    "$type": "color" }
      },
      "text": {
        "default": { "$value": "{color.text.primary}", "$type": "color" },
        "active":  { "$value": "{color.white}",        "$type": "color" }
      },
      "border-color": {
        "default": { "$value": "{color.border.default}", "$type": "color" },
        "hover":   { "$value": "{color.border.strong}",  "$type": "color" },
        "active":  { "$value": "{color.blue.500}",       "$type": "color" }
      },
      "disabled-opacity": { "$value": "{disabled.opacity}", "$type": "number" }
    },
    "input": {
      "width":   { "$value": 60,          "$type": "number" },
      "padding": { "$value": "{space.6}", "$type": "number" }
    },
    "text": {
      "font-size": { "$value": "{font.size.14}",      "$type": "number" },
      "color":     { "$value": "{color.text.secondary}", "$type": "color" }
    }
  },

  "link": {
    "font": {
      "size":   { "$value": "{font.size.14}",      "$type": "number" },
      "weight": { "$value": "{font.weight.normal}", "$type": "number" }
    },
    "color": {
      "default":  { "$value": "{color.blue.500}",    "$type": "color" },
      "hover":    { "$value": "{color.blue.600}",    "$type": "color" },
      "visited":  { "$value": "{color.purple.600}",  "$type": "color", "$description": "Visited link color — no semantic link-color token; intentional until link palette is defined" },
      "disabled": { "$value": "{color.text.disabled}", "$type": "color" }
    },
    "underline": {
      "default": { "$value": "none",      "$type": "string" },
      "hover":   { "$value": "underline", "$type": "string" }
    },
    "transition": { "$value": "{transition.base}", "$type": "number" }
  }
}
