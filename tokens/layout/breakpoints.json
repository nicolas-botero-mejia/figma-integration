{
  "$description": "Breakpoint and grid layout tokens. Figma collection: Layout (Desktop/Tablet/Mobile modes). Breakpoints are constants (same across all modes). Grid tokens vary per mode and use '$modes'.",
  "breakpoint": {
    "$description": "Viewport boundary constants — same value in all modes by design. These are breakpoint thresholds, not values that change per breakpoint.",
    "xs":  { "$type": "number", "$description": "320–480px — small phones",          "$modes": { "Desktop": 375,  "Tablet": 375,  "Mobile": 375  } },
    "sm":  { "$type": "number", "$description": "640px — small tablets/landscape",    "$modes": { "Desktop": 640,  "Tablet": 640,  "Mobile": 640  } },
    "md":  { "$type": "number", "$description": "768px — tablets",                    "$modes": { "Desktop": 768,  "Tablet": 768,  "Mobile": 768  } },
    "lg":  { "$type": "number", "$description": "1024px — small desktops",            "$modes": { "Desktop": 1024, "Tablet": 1024, "Mobile": 1024 } },
    "xl":  { "$type": "number", "$description": "1280px — standard desktops",         "$modes": { "Desktop": 1280, "Tablet": 1280, "Mobile": 1280 } },
    "2xl": { "$type": "number", "$description": "1536px — large desktops",            "$modes": { "Desktop": 1536, "Tablet": 1536, "Mobile": 1536 } }
  },
  "grid": {
    "columns": {
      "$type": "number",
      "$modes": {
        "Desktop": 12,
        "Tablet":  8,
        "Mobile":  4
      }
    },
    "gutter": {
      "$type": "number",
      "$description": "Horizontal gap between columns in px.",
      "$modes": {
        "Desktop": 24,
        "Tablet":  20,
        "Mobile":  16
      }
    },
    "margin": {
      "$type": "number",
      "$description": "Left/right page margin in px.",
      "$modes": {
        "Desktop": 32,
        "Tablet":  24,
        "Mobile":  16
      }
    },
    "max-width": { "$type": "number", "$description": "Max content container width in px — same across all viewports.", "$modes": { "Desktop": 1280, "Tablet": 1280, "Mobile": 1280 } }
  }
}
