{
  "$description": "Density-sensitive spacing tokens. Figma collection: Density (Comfortable/Compact/Spacious modes). When a token has '$modes' instead of '$value', the converter emits one Figma variable with a value per mode. Aliases use {space.N} primitives.",
  "density": {
    "component": {
      "padding": {
        "x": {
          "$type": "number",
          "$modes": {
            "Comfortable": "{space.12}",
            "Compact":     "{space.8}",
            "Spacious":    "{space.16}"
          }
        },
        "y": {
          "$type": "number",
          "$modes": {
            "Comfortable": "{space.8}",
            "Compact":     "{space.4}",
            "Spacious":    "{space.12}"
          }
        }
      },
      "height": {
        "$type": "number",
        "$description": "Component row/control height. Comfortable = WCAG AA minimum touch target.",
        "$modes": {
          "Comfortable": 40,
          "Compact":     32,
          "Spacious":    48
        }
      },
      "gap": {
        "$type": "number",
        "$modes": {
          "Comfortable": "{space.8}",
          "Compact":     "{space.6}",
          "Spacious":    "{space.12}"
        }
      }
    },
    "table": {
      "row-height": {
        "$type": "number",
        "$modes": {
          "Comfortable": 44,
          "Compact":     32,
          "Spacious":    56
        }
      },
      "cell-padding": {
        "x": {
          "$type": "number",
          "$modes": {
            "Comfortable": "{space.16}",
            "Compact":     "{space.12}",
            "Spacious":    "{space.20}"
          }
        },
        "y": {
          "$type": "number",
          "$modes": {
            "Comfortable": "{space.12}",
            "Compact":     "{space.6}",
            "Spacious":    "{space.16}"
          }
        }
      }
    }
  }
}
