{
  "$description": "Unitless px values. CSS output → px (sizing is visually fixed, not rem).",
  "size": {
    "icon": {
      "$description": "Standard icon sizes in px.",
      "xs":  { "$value": 12, "$type": "number" },
      "sm":  { "$value": 16, "$type": "number" },
      "md":  { "$value": 20, "$type": "number" },
      "lg":  { "$value": 24, "$type": "number" },
      "xl":  { "$value": 32, "$type": "number" },
      "2xl": { "$value": 40, "$type": "number" }
    },
    "component": {
      "$description": "Standard component touch target heights in px. Min 40px for WCAG AA.",
      "xs":  { "$value": 28, "$type": "number" },
      "sm":  { "$value": 32, "$type": "number" },
      "md":  { "$value": 40, "$type": "number" },
      "lg":  { "$value": 48, "$type": "number" },
      "xl":  { "$value": 56, "$type": "number" }
    }
  },
  "z": {
    "$description": "Z-index scale. Unitless integers.",
    "base":      { "$value": 0,    "$type": "number" },
    "raised":    { "$value": 100,  "$type": "number" },
    "dropdown":  { "$value": 1000, "$type": "number" },
    "sticky":    { "$value": 1100, "$type": "number" },
    "overlay":   { "$value": 1200, "$type": "number" },
    "modal":     { "$value": 1300, "$type": "number" },
    "toast":     { "$value": 1400, "$type": "number" },
    "tooltip":   { "$value": 1500, "$type": "number" }
  }
}
