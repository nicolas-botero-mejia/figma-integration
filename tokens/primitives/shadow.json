{
  "$description": "Drop shadow scale. CSS-ONLY — Figma uses Effect Styles for shadows, not Variables. All tokens carry $figmaExclude:true so the converter skips them. At CSS generation these become box-shadow values.",
  "shadow": {
    "none": { "$value": "none",                                                                        "$type": "string", "$figmaExclude": true },
    "xs":   { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)",                                               "$type": "string", "$figmaExclude": true },
    "sm":   { "$value": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)",               "$type": "string", "$figmaExclude": true },
    "md":   { "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",            "$type": "string", "$figmaExclude": true },
    "lg":   { "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)",          "$type": "string", "$figmaExclude": true },
    "xl":   { "$value": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)",         "$type": "string", "$figmaExclude": true },
    "2xl":  { "$value": "0 25px 50px -12px rgba(0,0,0,0.25)",                                         "$type": "string", "$figmaExclude": true }
  }
}
