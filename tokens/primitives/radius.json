{
  "$description": "Unitless px values. CSS output → px (not rem — border-radius is visually fixed).",
  "radius": {
    "0":    { "$value": 0,    "$type": "number" },
    "1":    { "$value": 1,    "$type": "number" },
    "2":    { "$value": 2,    "$type": "number" },
    "3":    { "$value": 3,    "$type": "number" },
    "4":    { "$value": 4,    "$type": "number" },
    "6":    { "$value": 6,    "$type": "number" },
    "8":    { "$value": 8,    "$type": "number" },
    "10":   { "$value": 10,   "$type": "number" },
    "12":   { "$value": 12,   "$type": "number" },
    "14":   { "$value": 14,   "$type": "number" },
    "16":   { "$value": 16,   "$type": "number" },
    "20":   { "$value": 20,   "$type": "number" },
    "24":   { "$value": 24,   "$type": "number" },
    "32":   { "$value": 32,   "$type": "number" },
    "full": { "$value": 9999, "$type": "number" }
  }
}
