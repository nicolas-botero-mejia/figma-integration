{
  "$description": "Focus and disabled state tokens. Referenced by all interactive component tokens.",
  "focus": {
    "outline": {
      "width":  { "$value": "{border.width.2}", "$type": "number" },
      "color":  { "$value": "{color.interactive.primary.default}", "$type": "color" },
      "offset": { "$value": "{space.2}", "$type": "number" }
    },
    "ring": {
      "width":  { "$value": "{border.width.4}", "$type": "number" },
      "color":  { "$value": "{color.blue.200}", "$type": "color" },
      "offset": { "$value": "{space.2}", "$type": "number" }
    }
  },
  "disabled": {
    "opacity": { "$value": "{opacity.50}", "$type": "number" },
    "cursor":  { "$value": "not-allowed", "$type": "string" }
  }
}
