{
  "$description": "All semantic color tokens. Every $value is a {path.to.primitive} alias — no hardcoded hex. Swap themes at this layer only.",
  "color": {
    "text": {
      "primary":    { "$value": "{color.neutral.900}", "$type": "color" },
      "secondary":  { "$value": "{color.neutral.600}", "$type": "color" },
      "tertiary":   { "$value": "{color.neutral.500}", "$type": "color" },
      "quaternary": { "$value": "{color.neutral.400}", "$type": "color" },
      "disabled":   { "$value": "{color.neutral.300}", "$type": "color" },
      "inverse":    { "$value": "{color.white}",        "$type": "color" },
      "success":    { "$value": "{color.success.700}", "$type": "color" },
      "warning":    { "$value": "{color.warning.700}", "$type": "color" },
      "error":      { "$value": "{color.error.700}",   "$type": "color" },
      "info":       { "$value": "{color.info.700}",    "$type": "color" }
    },
    "bg": {
      "primary":        { "$value": "{color.white}",         "$type": "color" },
      "secondary":      { "$value": "{color.neutral.50}",    "$type": "color" },
      "tertiary":       { "$value": "{color.neutral.100}",   "$type": "color" },
      "quaternary":     { "$value": "{color.neutral.200}",   "$type": "color" },
      "disabled":       { "$value": "{color.neutral.100}",   "$type": "color" },
      "success":        { "$value": "{color.success.50}",    "$type": "color" },
      "success-muted":  { "$value": "{color.success.100}",   "$type": "color" },
      "warning":        { "$value": "{color.warning.50}",    "$type": "color" },
      "warning-muted":  { "$value": "{color.warning.100}",   "$type": "color" },
      "error":          { "$value": "{color.error.50}",      "$type": "color" },
      "error-muted":    { "$value": "{color.error.100}",     "$type": "color" },
      "info":           { "$value": "{color.info.50}",       "$type": "color" },
      "info-muted":     { "$value": "{color.info.100}",      "$type": "color" },
      "overlay":        { "$value": "rgba(0,0,0,0.5)", "$type": "string", "$description": "CSS-only — no Figma Color Variable equivalent for rgba" },
      "overlay-light":  { "$value": "rgba(0,0,0,0.3)", "$type": "string", "$description": "CSS-only" }
    },
    "border": {
      "light":    { "$value": "{color.neutral.150}", "$type": "color" },
      "default":  { "$value": "{color.neutral.300}", "$type": "color" },
      "strong":   { "$value": "{color.neutral.400}", "$type": "color" },
      "disabled": { "$value": "{color.neutral.200}", "$type": "color" },
      "success":  { "$value": "{color.success.300}", "$type": "color" },
      "warning":  { "$value": "{color.warning.300}", "$type": "color" },
      "error":    { "$value": "{color.error.300}",   "$type": "color" },
      "info":     { "$value": "{color.info.300}",    "$type": "color" }
    },
    "interactive": {
      "primary": {
        "default":  { "$value": "{color.blue.500}", "$type": "color" },
        "hover":    { "$value": "{color.blue.600}", "$type": "color" },
        "pressed":  { "$value": "{color.blue.700}", "$type": "color" },
        "disabled": { "$value": "{color.neutral.300}", "$type": "color" },
        "focus":    { "$value": "{color.blue.500}", "$type": "color" }
      },
      "secondary": {
        "default":  { "$value": "{color.neutral.200}", "$type": "color" },
        "hover":    { "$value": "{color.neutral.300}", "$type": "color" },
        "pressed":  { "$value": "{color.neutral.400}", "$type": "color" },
        "disabled": { "$value": "{color.neutral.200}", "$type": "color" },
        "text":     { "$value": "{color.neutral.900}", "$type": "color" }
      },
      "tertiary": {
        "default":  { "$value": "{color.transparent}",  "$type": "color" },
        "hover":    { "$value": "{color.neutral.100}",  "$type": "color" },
        "pressed":  { "$value": "{color.neutral.200}",  "$type": "color" },
        "text":     { "$value": "{color.blue.500}",     "$type": "color" }
      },
      "danger": {
        "default":  { "$value": "{color.error.500}", "$type": "color" },
        "hover":    { "$value": "{color.error.600}", "$type": "color" },
        "pressed":  { "$value": "{color.error.700}", "$type": "color" },
        "disabled": { "$value": "{color.neutral.300}", "$type": "color" }
      },
      "success": {
        "default":  { "$value": "{color.success.500}", "$type": "color" },
        "hover":    { "$value": "{color.success.600}", "$type": "color" },
        "pressed":  { "$value": "{color.success.700}", "$type": "color" },
        "disabled": { "$value": "{color.neutral.300}", "$type": "color" }
      }
    },
    "feedback": {
      "success": { "$value": "{color.success.500}", "$type": "color" },
      "warning": { "$value": "{color.warning.500}", "$type": "color" },
      "error":   { "$value": "{color.error.500}",   "$type": "color" },
      "info":    { "$value": "{color.info.500}",    "$type": "color" }
    },
    "chart": {
      "1":       { "$value": "{color.blue.500}",    "$type": "color" },
      "2":       { "$value": "{color.success.500}", "$type": "color" },
      "3":       { "$value": "{color.warning.500}", "$type": "color" },
      "4":       { "$value": "{color.error.500}",   "$type": "color" },
      "5":       { "$value": "{color.info.500}",    "$type": "color" },
      "6":       { "$value": "{color.purple.500}",  "$type": "color" },
      "7":       { "$value": "{color.cyan.500}",    "$type": "color" },
      "8":       { "$value": "{color.indigo.500}",  "$type": "color" },
      "neutral": { "$value": "{color.neutral.500}", "$type": "color" }
    }
  }
}
