{
  "card": {
    "padding": {
      "$type": "number",
      "$value": "{space.16}"
    },
    "border": {
      "radius": {
        "$type": "number",
        "$value": "{radius.8}"
      },
      "width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "color": {
        "$type": "color",
        "$value": "{color.border.light}"
      }
    },
    "bg": {
      "default": {
        "$type": "color",
        "$value": "{color.bg.primary}"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.bg.secondary}"
      }
    },
    "transition": {
      "$type": "number",
      "$value": "{transition.base}"
    },
    "header": {
      "padding": {
        "$type": "number",
        "$value": "{space.16}"
      },
      "border-width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "border-color": {
        "$type": "color",
        "$value": "{color.border.light}"
      }
    },
    "body": {
      "padding": {
        "$type": "number",
        "$value": "{space.16}"
      },
      "text": {
        "$type": "color",
        "$value": "{color.text.primary}"
      }
    },
    "footer": {
      "padding": {
        "$type": "number",
        "$value": "{space.16}"
      },
      "border-width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "border-color": {
        "$type": "color",
        "$value": "{color.border.light}"
      },
      "bg": {
        "$type": "color",
        "$value": "{color.bg.secondary}"
      }
    }
  },
  "modal": {
    "border-radius": {
      "$type": "number",
      "$value": "{radius.8}"
    },
    "bg": {
      "$type": "color",
      "$value": "{color.bg.primary}"
    },
    "padding": {
      "$type": "number",
      "$value": "{space.24}"
    },
    "max-width": {
      "sm": {
        "$type": "number",
        "$value": 400
      },
      "md": {
        "$type": "number",
        "$value": 600
      },
      "lg": {
        "$type": "number",
        "$value": 800
      },
      "xl": {
        "$type": "number",
        "$value": 1000
      }
    },
    "header": {
      "padding": {
        "$type": "number",
        "$value": "{space.24}"
      },
      "border-width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "border-color": {
        "$type": "color",
        "$value": "{color.border.light}"
      }
    },
    "body": {
      "padding": {
        "$type": "number",
        "$value": "{space.24}"
      }
    },
    "footer": {
      "padding": {
        "$type": "number",
        "$value": "{space.24}"
      },
      "border-width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "border-color": {
        "$type": "color",
        "$value": "{color.border.light}"
      },
      "bg": {
        "$type": "color",
        "$value": "{color.bg.secondary}"
      },
      "gap": {
        "$type": "number",
        "$value": "{space.12}"
      }
    },
    "close-button": {
      "size": {
        "$type": "number",
        "$value": "{size.icon.lg}"
      },
      "color": {
        "$type": "color",
        "$value": "{color.text.secondary}"
      }
    },
    "backdrop": {
      "transition": {
        "$type": "number",
        "$value": "{transition.base}"
      }
    },
    "transition": {
      "$type": "number",
      "$value": "{transition.base}"
    }
  },
  "divider": {
    "height": {
      "$type": "number",
      "$value": "{border.width.1}"
    },
    "color": {
      "$type": "color",
      "$value": "{color.border.light}"
    },
    "margin": {
      "x": {
        "$type": "number",
        "$value": "{space.0}"
      },
      "y": {
        "$type": "number",
        "$value": "{space.16}"
      }
    },
    "text": {
      "margin": {
        "$type": "number",
        "$value": "{space.12}"
      },
      "size": {
        "$type": "number",
        "$value": "{font.size.12}"
      },
      "color": {
        "$type": "color",
        "$value": "{color.text.secondary}"
      }
    }
  },
  "accordion": {
    "border": {
      "width": {
        "$type": "number",
        "$value": "{border.width.default}"
      },
      "color": {
        "$type": "color",
        "$value": "{color.border.light}"
      },
      "radius": {
        "$type": "number",
        "$value": "{radius.6}"
      }
    },
    "header": {
      "padding": {
        "x": {
          "$type": "number",
          "$value": "{space.16}"
        },
        "y": {
          "$type": "number",
          "$value": "{space.12}"
        }
      },
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.bg.secondary}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.bg.tertiary}"
        }
      },
      "font": {
        "size": {
          "$type": "number",
          "$value": "{font.size.14}"
        },
        "weight": {
          "$type": "number",
          "$value": "{font.weight.semibold}"
        }
      },
      "text": {
        "$type": "color",
        "$value": "{color.text.primary}"
      }
    },
    "icon": {
      "size": {
        "$type": "number",
        "$value": "{size.icon.md}"
      },
      "color": {
        "$type": "color",
        "$value": "{color.text.secondary}"
      },
      "rotation-open": {
        "$type": "string",
        "$value": "180deg"
      }
    },
    "body": {
      "padding": {
        "$type": "number",
        "$value": "{space.16}"
      },
      "bg": {
        "$type": "color",
        "$value": "{color.bg.primary}"
      },
      "text": {
        "$type": "color",
        "$value": "{color.text.primary}"
      }
    },
    "transition": {
      "$type": "number",
      "$value": "{transition.base}"
    }
  }
}
