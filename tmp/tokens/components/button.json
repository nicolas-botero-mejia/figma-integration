{
  "button": {
    "padding": {
      "sm": {
        "x": {
          "$type": "number",
          "$value": "{space.12}"
        },
        "y": {
          "$type": "number",
          "$value": "{space.6}"
        }
      },
      "md": {
        "x": {
          "$type": "number",
          "$value": "{space.16}"
        },
        "y": {
          "$type": "number",
          "$value": "{space.8}"
        }
      },
      "lg": {
        "x": {
          "$type": "number",
          "$value": "{space.20}"
        },
        "y": {
          "$type": "number",
          "$value": "{space.12}"
        }
      }
    },
    "border": {
      "radius": {
        "$type": "number",
        "$value": "{radius.6}"
      },
      "width": {
        "$type": "number",
        "$value": "{border.width.default}"
      }
    },
    "font": {
      "size": {
        "$type": "number",
        "$value": "{font.size.16}"
      },
      "weight": {
        "$type": "number",
        "$value": "{font.weight.semibold}"
      },
      "leading": {
        "$type": "number",
        "$value": "{font.leading.150}"
      }
    },
    "size": {
      "min-height": {
        "$type": "number",
        "$value": "{size.component.md}"
      },
      "min-width": {
        "$type": "number",
        "$value": 80
      }
    },
    "focus": {
      "outline-width": {
        "$type": "number",
        "$value": "{focus.outline.width}"
      },
      "outline-color": {
        "$type": "color",
        "$value": "{focus.outline.color}"
      },
      "outline-offset": {
        "$type": "number",
        "$value": "{focus.outline.offset}"
      }
    },
    "disabled": {
      "opacity": {
        "$type": "number",
        "$value": "{disabled.opacity}"
      },
      "cursor": {
        "$type": "string",
        "$value": "{disabled.cursor}"
      }
    },
    "transition": {
      "$type": "number",
      "$value": "{transition.base}"
    },
    "primary": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.primary.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.primary.hover}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.primary.pressed}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.interactive.primary.disabled}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.white}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.text.disabled}"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "{color.transparent}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.transparent}"
        }
      }
    },
    "secondary": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.secondary.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.secondary.hover}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.secondary.pressed}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.interactive.secondary.disabled}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.secondary.text}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.text.disabled}"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "{color.border.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.border.strong}"
        }
      }
    },
    "tertiary": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.tertiary.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.tertiary.hover}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.tertiary.pressed}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.tertiary.text}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.primary.hover}"
        }
      }
    },
    "danger": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.danger.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.danger.hover}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.danger.pressed}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.interactive.danger.disabled}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.white}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.text.disabled}"
        }
      }
    },
    "success": {
      "bg": {
        "default": {
          "$type": "color",
          "$value": "{color.interactive.success.default}"
        },
        "hover": {
          "$type": "color",
          "$value": "{color.interactive.success.hover}"
        },
        "pressed": {
          "$type": "color",
          "$value": "{color.interactive.success.pressed}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{color.white}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.text.disabled}"
        }
      }
    }
  }
}
