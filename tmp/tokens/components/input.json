{
  "input": {
    "padding": {
      "x": {
        "$type": "number",
        "$value": "{space.12}"
      },
      "y": {
        "$type": "number",
        "$value": "{space.8}"
      }
    },
    "border": {
      "radius": {
        "$type": "number",
        "$value": "{radius.4}"
      },
      "width": {
        "$type": "number",
        "$value": "{border.width.default}"
      }
    },
    "font": {
      "size": {
        "$type": "number",
        "$value": "{font.size.16}"
      },
      "family": {
        "$type": "fontFamily",
        "$value": "{font.family.sans}"
      },
      "weight": {
        "$type": "number",
        "$value": "{font.weight.normal}"
      },
      "leading": {
        "$type": "number",
        "$value": "{font.leading.150}"
      }
    },
    "size": {
      "min-height": {
        "$type": "number",
        "$value": "{size.component.md}"
      }
    },
    "bg": {
      "default": {
        "$type": "color",
        "$value": "{color.bg.primary}"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.bg.primary}"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.bg.primary}"
      },
      "disabled": {
        "$type": "color",
        "$value": "{color.bg.disabled}"
      },
      "readonly": {
        "$type": "color",
        "$value": "{color.bg.disabled}"
      }
    },
    "text": {
      "default": {
        "$type": "color",
        "$value": "{color.text.primary}"
      },
      "disabled": {
        "$type": "color",
        "$value": "{color.text.disabled}"
      },
      "readonly": {
        "$type": "color",
        "$value": "{color.text.secondary}"
      },
      "placeholder": {
        "default": {
          "$type": "color",
          "$value": "{color.text.tertiary}"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.text.quaternary}"
        }
      }
    },
    "border-color": {
      "default": {
        "$type": "color",
        "$value": "{color.border.default}"
      },
      "hover": {
        "$type": "color",
        "$value": "{color.border.strong}"
      },
      "focus": {
        "$type": "color",
        "$value": "{color.interactive.primary.default}"
      },
      "disabled": {
        "$type": "color",
        "$value": "{color.border.disabled}"
      },
      "readonly": {
        "$type": "color",
        "$value": "{color.border.default}"
      },
      "error": {
        "$type": "color",
        "$value": "{color.border.error}"
      },
      "success": {
        "$type": "color",
        "$value": "{color.border.success}"
      },
      "warning": {
        "$type": "color",
        "$value": "{color.border.warning}"
      }
    },
    "bg-status": {
      "error": {
        "$type": "color",
        "$value": "{color.bg.error}"
      },
      "success": {
        "$type": "color",
        "$value": "{color.bg.success}"
      },
      "warning": {
        "$type": "color",
        "$value": "{color.bg.warning}"
      }
    },
    "focus": {
      "outline-width": {
        "$type": "number",
        "$value": "{focus.outline.width}"
      },
      "outline-color": {
        "$type": "color",
        "$value": "{focus.outline.color}"
      },
      "outline-offset": {
        "$type": "number",
        "$value": "{focus.outline.offset}"
      }
    },
    "transition": {
      "$type": "number",
      "$value": "{transition.base}"
    }
  }
}
