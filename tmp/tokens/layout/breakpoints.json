{
  "breakpoint": {
    "xs": {
      "$type": "number",
      "$modes": {
        "Desktop": 375,
        "Tablet": 375,
        "Mobile": 375
      }
    },
    "sm": {
      "$type": "number",
      "$modes": {
        "Desktop": 640,
        "Tablet": 640,
        "Mobile": 640
      }
    },
    "md": {
      "$type": "number",
      "$modes": {
        "Desktop": 768,
        "Tablet": 768,
        "Mobile": 768
      }
    },
    "lg": {
      "$type": "number",
      "$modes": {
        "Desktop": 1024,
        "Tablet": 1024,
        "Mobile": 1024
      }
    },
    "xl": {
      "$type": "number",
      "$modes": {
        "Desktop": 1280,
        "Tablet": 1280,
        "Mobile": 1280
      }
    },
    "2xl": {
      "$type": "number",
      "$modes": {
        "Desktop": 1536,
        "Tablet": 1536,
        "Mobile": 1536
      }
    }
  },
  "grid": {
    "columns": {
      "$type": "number",
      "$modes": {
        "Desktop": 12,
        "Tablet": 8,
        "Mobile": 4
      }
    },
    "gutter": {
      "$type": "number",
      "$modes": {
        "Desktop": 24,
        "Tablet": 20,
        "Mobile": 16
      }
    },
    "margin": {
      "$type": "number",
      "$modes": {
        "Desktop": 32,
        "Tablet": 24,
        "Mobile": 16
      }
    },
    "max-width": {
      "$type": "number",
      "$modes": {
        "Desktop": 1280,
        "Tablet": 1280,
        "Mobile": 1280
      }
    }
  }
}
